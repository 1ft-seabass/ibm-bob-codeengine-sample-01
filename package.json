{
  "name": "ibm-ce-simple-nodejs-hono-base",
  "version": "1.0.0",
  "description": "This is a simple Node.js Hono IBM Code Engine base repository.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "build:image_build": "dotenv -e .env.ce -- ibmcloud ce buildrun submit --build $CE_BUILD_NAME --wait",
    "build:update_app": "dotenv -e .env.ce -- ibmcloud ce application update --name $CE_APP_NAME --image $CE_BUILD_IMAGE --wait",
    "build": "npm run build:image_build && npm run build:update_app",
    "security:verify": "node scripts/security-verify.js",
    "security:verify:simple": "node scripts/security-verify.js --simple",
    "security:verify:testrun": "node scripts/security-verify.js --test-run",
    "security:install-gitleaks": "node scripts/install-gitleaks.js",
    "secret-scan": "secretlint \"**/*\"",
    "secret-scan:full": "secretlint \"**/*\" && ./bin/gitleaks detect --source . -v --config gitleaks.toml",
    "postinstall": "npx simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "node scripts/pre-commit.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/1ft-seabass/ibm-ce-simple-nodejs-hono-base.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/1ft-seabass/ibm-ce-simple-nodejs-hono-base/issues"
  },
  "homepage": "https://github.com/1ft-seabass/ibm-ce-simple-nodejs-hono-base#readme",
  "dependencies": {
    "hono": "^4.0.0",
    "@hono/node-server": "^1.0.0"
  },
  "devDependencies": {
    "@secretlint/secretlint-rule-preset-recommend": "^13.0.2",
    "dotenv-cli": "^8.0.0",
    "secretlint": "^13.0.2",
    "simple-git-hooks": "^2.13.1"
  }
}
